{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role management details",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "Firebase user's unique authentication ID"
        },
        "email": {
          "type": "string",
          "description": "User's Google Account email"
        },
        "displayName": {
          "type": "string",
          "description": "User's visible name"
        },
        "photoURL": {
          "type": "string",
          "description": "User's profile image URL"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "member", "guest", "blocked"],
          "description": "Access level of the user"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of user sign up"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of profile update"
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Game": {
      "title": "Game",
      "description": "Game details inside the user's library dashboard",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique key identifier"
        },
        "name": {
          "type": "string",
          "description": "Game name"
        },
        "coverUrl": {
          "type": "string",
          "description": "Big card cover layout link"
        },
        "category": {
          "type": "string",
          "description": "Game genre category"
        },
        "playtime": {
          "type": "number",
          "description": "Hours accumulated"
        },
        "lastPlayed": {
          "type": "string",
          "description": "YMD format date or unplayed"
        },
        "review": {
          "type": "string",
          "description": "Review and personal feedback"
        },
        "rating": {
          "type": "number",
          "description": "Score from 1 to 10"
        },
        "snippets": {
          "type": "array",
          "description": "Screenshots"
        },
        "launchUrl": {
          "type": "string",
          "description": "Execution startup link"
        },
        "isLocal": {
          "type": "boolean",
          "description": "Imported sandbox"
        },
        "tags": {
          "type": "array",
          "description": "Meta descriptors list"
        },
        "status": {
          "type": "string",
          "enum": ["Played", "Backlog", "Playing"],
          "description": "Gameplay queue state"
        },
        "ownerUid": {
          "type": "string",
          "description": "UID of the owner who added the game"
        }
      },
      "required": ["id", "name", "coverUrl", "category", "playtime", "rating", "status"]
    },
    "Activity": {
      "title": "Activity",
      "description": "An interactive post in the community activity stream",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique record ID"
        },
        "user": {
          "type": "object",
          "description": "Author user data summary"
        },
        "gameName": {
          "type": "string",
          "description": "Title of the associated game"
        },
        "action": {
          "type": "string",
          "description": "Event trigger text"
        },
        "content": {
          "type": "string",
          "description": "Description feedback"
        },
        "images": {
          "type": "array",
          "description": "Image gallery content links"
        },
        "likes": {
          "type": "number",
          "description": "Sum of counts"
        },
        "likedBy": {
          "type": "array",
          "description": "Array of user UIDs who liked the activity"
        },
        "comments": {
          "type": "array",
          "description": "Embedded comments"
        },
        "timestamp": {
          "type": "string",
          "description": "Datetime string or relative label"
        }
      },
      "required": ["id", "user", "gameName", "action", "likes", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Storage space for personal role and details"
    },
    "/games/{gameId}": {
      "schema": "Game",
      "description": "Main games records accessible by users according to roles"
    },
    "/activities/{activityId}": {
      "schema": "Activity",
      "description": "Timeline of friend actions and custom screenshots"
    }
  }
}
