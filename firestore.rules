rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Defending Nets - Zero Trust Deny-All Default
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable validation gates
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email != null);
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Role Resolution logic (Explicitly avoids claiming mock systems)
    function isAdmin() {
      return isSignedIn() && isEmailVerified() && (
        request.auth.token.email == 'tangyufeng95@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function isAuthorized() {
      return isAdmin() || (
        isSignedIn() && isEmailVerified() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'member'
      );
    }
    
    function isNotBlocked() {
      return isSignedIn() && (
        !exists(/databases/$(database)/documents/users/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role != 'blocked'
      );
    }

    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // Strong Object schema validators to shield Database States
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 200 &&
             (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100)) &&
             (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 2048)) &&
             data.role is string && (data.role == 'admin' || data.role == 'member' || data.role == 'guest' || data.role == 'blocked');
    }

    function isValidGame(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 250 &&
             data.coverUrl is string && data.coverUrl.size() <= 2048 &&
             data.category is string && data.category.size() <= 100 &&
             data.playtime is number && data.playtime >= 0 &&
             data.lastPlayed is string && data.lastPlayed.size() <= 50 &&
             data.review is string && data.review.size() <= 10000 &&
             data.rating is number && data.rating >= 0 && data.rating <= 10 &&
             data.launchUrl is string && data.launchUrl.size() <= 2048 &&
             data.isLocal is bool &&
             data.status is string && (data.status == 'Played' || data.status == 'Backlog' || data.status == 'Playing') &&
             data.ownerUid is string && data.ownerUid.size() <= 128 &&
             data.tags is list && data.tags.size() <= 30 &&
             (data.tags.size() == 0 || data.tags[0] is string) &&
             data.snippets is list && data.snippets.size() <= 10 &&
             (data.snippets.size() == 0 || data.snippets[0] is string);
    }

    function isValidActivity(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.gameName is string && data.gameName.size() <= 250 &&
             data.action is string && data.action.size() <= 250 &&
             (data.content == null || (data.content is string && data.content.size() <= 5000)) &&
             data.likes is number && data.likes >= 0 &&
             data.timestamp is string && data.timestamp.size() <= 100 &&
             data.user is map &&
             data.user.name is string && data.user.name.size() <= 100 &&
             data.user.avatar is string && data.user.avatar.size() <= 2048 &&
             data.likedBy is list && data.likedBy.size() <= 1000 &&
             data.comments is list && data.comments.size() <= 1000 &&
             (data.images == null || (data.images is list && data.images.size() <= 10));
    }

    // Matching Collections
    match /users/{userId} {
      allow read: if isNotBlocked();
      allow create: if (
        isSignedIn() && isEmailVerified() && userId == request.auth.uid && isValidUser(incoming()) && (
          (request.auth.token.email == 'tangyufeng95@gmail.com' && incoming().role == 'admin') ||
          (request.auth.token.email != 'tangyufeng95@gmail.com' && incoming().role == 'guest')
        )
      ) || isAdmin();
      
      allow update: if (
        isAdmin() && isValidUser(incoming())
      ) || (
        isSignedIn() && isEmailVerified() && userId == request.auth.uid && isNotBlocked() && isValidUser(incoming()) && (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt'])
        )
      );
      
      allow delete: if isAdmin();
    }

    match /games/{gameId} {
      allow read: if isNotBlocked();
      allow create: if isAuthorized() && isValidId(gameId) && isValidGame(incoming()) && incoming().ownerUid == request.auth.uid;
      allow update: if isAuthorized() && isValidId(gameId) && isValidGame(incoming()) && (
        isAdmin() || (incoming().ownerUid == existing().ownerUid)
      );
      allow delete: if isAdmin() || (isAuthorized() && existing().ownerUid == request.auth.uid);
    }

    match /activities/{activityId} {
      allow read: if isNotBlocked();
      allow create: if isAuthorized() && isValidId(activityId) && isValidActivity(incoming());
      allow update: if isAuthorized() && isValidId(activityId) && isValidActivity(incoming());
      allow delete: if isAdmin();
    }
  }
}
